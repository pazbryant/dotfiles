[Default Applications]
# use this command to update types
# update-mime-database ~/.local/share/mime

# Previously defined text types...
text/plain=st -e nvim %U;
text/markdown=st -e nvim %U;

# Programming Languages
text/x-python=st -e nvim %U;
text/x-c=st -e nvim %U;
text/x-c++=st -e nvim %U;
text/x-java=st -e nvim %U;
text/x-javascript=st -e nvim %U;
text/typescript=st -e nvim %U;
text/x-php=st -e nvim %U;
text/x-ruby=st -e nvim %U;
text/x-rust=st -e nvim %U;
text/x-haskell=st -e nvim %U;
text/x-lua=st -e nvim %U;
text/x-go=st -e nvim %U;
text/x-scala=st -e nvim %U;
text/x-kotlin=st -e nvim %U;

# Development Config Files
text/x-cmake=st -e nvim %U;
text/x-makefile=st -e nvim %U;
text/x-maven+xml=st -e nvim %U;
text/x-gradle=st -e nvim %U;
application/x-yaml=st -e nvim %U;
application/xml=st -e nvim %U;
application/json=st -e nvim %U;
text/x-properties=st -e nvim %U;
text/x-toml=st -e nvim %U;
application/x-shellscript=st -e nvim %U;
text/x-dockerfile=st -e nvim %U;
application/x-xauthority=st -e nvim %U;
application/octet-stream=st -e nvim %U;

# Development Documentation
application/x-docbook+xml=st -e nvim %U;
text/x-tex=st -e nvim %U;
text/x-markdown=st -e nvim %U;
text/x-rst=st -e nvim %U;
text/asciidoc=st -e nvim %U;

# Database Files
application/sql=st -e nvim %U;
application/x-sqlite3=st -e nvim %U;

# Version Control
text/x-diff=st -e nvim %U;
text/x-patch=st -e nvim %U;
text/x-git-config=st -e nvim %U;

# Executables and Binaries
application/x-executable=alacritty.desktop
application/x-sharedlib=st -e nvim %U;
application/x-object=st -e nvim %U;

# Web Development
text/html=st -e nvim %U;
text/css=st -e nvim %U;
text/scss=st -e nvim %U;
text/less=st -e nvim %U;
application/javascript=st -e nvim %U;
application/typescript=st -e nvim %U;
application/graphql=st -e nvim %U;
application/json=st -e nvim %U;

# Images
image/jpeg=imv.desktop
image/png=imv.desktop
image/gif=imv.desktop
image/webp=imv.desktop
image/tiff=imv.desktop
image/svg+xml=imv.desktop
image/x-xcf=imv.desktop
image/bmp=imv.desktop

# Videos
video/mp4=mpv.desktop
video/x-matroska=mpv.desktop
video/webm=mpv.desktop
video/quicktime=mpv.desktop
video/x-msvideo=mpv.desktop
video/mpeg=mpv.desktop

# Audio
audio/mpeg=ncmpcpp.desktop
audio/mp4=ncmpcpp.desktop
audio/flac=ncmpcpp.desktop
audio/ogg=ncmpcpp.desktop
audio/wav=ncmpcpp.desktop
audio/webm=ncmpcpp.desktop
audio/x-wav=ncmpcpp.desktop

# Documents
application/pdf=org.pwmt.zathura.desktop
application/epub+zip=org.pwmt.zathura.desktop
application/x-mobipocket-ebook=org.pwmt.zathura.desktop
application/x-fictionbook+xml=org.pwmt.zathura.desktop

# Web content
x-scheme-handler/http=firefox.desktop
x-scheme-handler/https=firefox.desktop
x-scheme-handler/ftp=firefox.desktop
x-scheme-handler/chrome=firefox.desktop
application/x-extension-htm=firefox.desktop
application/x-extension-html=firefox.desktop
application/x-extension-shtml=firefox.desktop
application/xhtml+xml=firefox.desktop
application/x-extension-xhtml=firefox.desktop
application/x-extension-xht=firefox.desktop
