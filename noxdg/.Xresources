! Global font configuration
*font: Maple Mono Normal:pixelsize=13.5:style:Medium
*boldFont: Maple Mono Normal:pixelsize=13.5:style:Bold
*italicFont: Maple Mono Normal:pixelsize=13.5:style:Italic
*boldItalicFont: Maple Mono Normal:pixelsize=13.5:style:Bold Italic

! Global colors
st.background: #1d1f21
st.foreground: #ffffff
*cursorColor: #862d59

! ST specific configurations
st.borderpx: 10
st.cwscale: 1.20
st.chscale: 1.00
st.alpha: 0.87
