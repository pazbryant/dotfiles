Xft.antialias:	1
Xft.hinting:	1
Xft.autohint:	0
Xft.hintstyle:	hintslight
Xft.rgba:	rgb
Xft.lcdfilter:	lcddefault

! font family
st.font: Maple Mono NF:pixelsize=15:style:Medium

! window padding
st.borderpx: 0

! font horizontal spacing
st.cwscale: 1.05
st.chscale: 1.05

! transparency
st.alpha: 0.9
