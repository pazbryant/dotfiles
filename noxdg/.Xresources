Xft.antialias:	1
Xft.hinting:	1
Xft.autohint:	0
Xft.hintstyle:	hintslight
Xft.rgba:	rgb
Xft.lcdfilter:	lcddefault

! Global colors
*background: #1d1f21
*foreground: #ffffff
*cursorColor: #ffffff

! Global font configuration
*st.font: Maple Mono NF:pixelsize=13:style:SemiBold

! ST specific configurations
*st.borderpx: 10
*st.cwscale: 1.25
*st.chscale: 1.00
*st.alpha: 0.70
