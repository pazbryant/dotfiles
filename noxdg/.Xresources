! Global font configuration
*font: Maple Mono Normal:pixelsize=14:style:Medium
*boldFont: Maple Mono Normal:pixelsize=14:style:Bold
*italicFont: Maple Mono Normal:pixelsize=14:style:Italic
*boldItalicFont: Maple Mono Normal:pixelsize=14:style:Bold Italic

! Global colors
st.background: #1d1f21
st.foreground: #ffffff
*cursorColor: #76ccbc

! ST specific configurations
st.borderpx: 0
st.cwscale: 1.15
st.chscale: 1.00
st.alpha: 0.87
