#!/usr/bin/env sh

showk() {
  if [ "$1" = "" ]; then
    echo "Usage: showk script.sh"
    return 1
  fi

  xdg-mime query filetype "$1"
}

setk() {
  # app.desktop | mime-type
  if [ "$1" = "" ] && [ "$2" = "" ]; then
    echo "Usage: setk nvim.desktop text/x-shellscript"
    return 1
  fi
  xdg-mime default "$1" "$2"
}

whichk() {
  # mime-type
  if [ "$1" = "" ]; then
    echo "Usage: whichk text/x-shellscript"
    return 1
  fi
  xdg-mime query default "$1"
}
