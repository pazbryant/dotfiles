#!/usr/bin/env sh

SSH_DIR="$HOME/.ssh/private"

get_passphrase() {
  # WARN: The way passphrase is named is the same as my github ssh-private keys,
  # in this case I use, `personal/work_plataform`.
  # Example: 'personal_github' or 'work_github'

  # NOTE: 'ssh/my_passphrase' is how I have structured my default `pass`
  # folder and their files, whene my_passphrase is the `.gpg` file that get
  # decripted and then returned as a string text.

  selected_passphrase=$(pass show "ssh/$1")
  echo "$selected_passphrase"
}

get_private_key_name() {
  fd --base-directory "$SSH_DIR" |
    fzf --header="Select your ssh private key file"
}

start_ssh_agent() {
  if [ -z "$SSH_AUTH_SOCK" ]; then
    eval "$(ssh-agent -s)" >/dev/null 2>&1
  fi
}

authenticate() {
  if ! timeout 2s sshpass -P "Enter passphrase" -p "$2" \
    ssh-add "$SSH_DIR/$1" >/dev/null 2>&1; then
    echo "Error: passphrase or key are invalid"
    return 1
  fi

  return 0
}

main() {
  private_key=$(get_private_key_name)

  if [ -z "$private_key" ]; then
    exit 1
  fi

  passphrase=$(get_passphrase "$private_key")

  if [ -z "$passphrase" ]; then
    echo "Passphrase has not been selected or is invalid"
    exit 1
  fi

  start_ssh_agent

  authenticate "$private_key" "$passphrase"

  unset "$passphrase" # make sure passphrase is not saved in memory
}

main
