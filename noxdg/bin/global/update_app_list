#!/bin/sh

set -x

sync_system_apps() {
  sudo pacman -Qen | sort >"$1/installed_apps.txt"
}

sync_python_apps() {
  fd . -d 1 /home/bryant/.local/bin | awk -F/ '{print $NF}' |
    sort >"$1/pipx_installed.txt"
}

sync_rust_apps() {
  fd . -d 1 -t f /home/bryant/.cargo/bin | awk -F/ '{print $NF}' |
    sort >"$1/cargo_installed.txt"
}

sync_go_apps() {
  fd . -d 1 -t f /home/bryant/go/bin | awk -F/ '{print $NF}' |
    sort >"$1/go_installed.txt"
}

sync_flatpak_apps() {
  flatpak list | sort >"$1/flatpak_installed.txt"
}

sync_aur_apps() {
  paru -Qm | sort >"$1/installed_aur_apps.txt"
}

commit_changes_to_git() {
  FORMATTED_DATE=$(date "+%B %d, %Y")

  if [ -z "$1" ]; then
    echo "Error: Please provide a directory path"
    return 1
  fi

  cd "$1" || {
    echo "Error: Could not change to directory $1"
    return 1
  }

  git add .
  git commit -m "Update system apps, $FORMATTED_DATE"

}

main() {
  dot_path="/home/bryant/Documents/github/dotfiles/apps"

  sync_system_apps $dot_path
  sync_python_apps $dot_path
  sync_rust_apps $dot_path
  sync_go_apps $dot_path
  sync_flatpak_apps $dot_path
  sync_aur_apps $dot_path

  commit_changes_to_git "$dot_path"
}

main
