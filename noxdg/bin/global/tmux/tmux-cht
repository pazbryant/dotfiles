#!/bin/sh

defaults_file="$HOME/.tmux-cht-defaults"
commands_file="$HOME/.tmux-cht-commands"
languages_file="$HOME/.tmux-cht-languages"

safe_print() {
    printf '%s' "$1"
}

tmux_curl() {
    url="cht.sh/$1"
    tmux neww sh -c "curl -s '$url' | bat --paging=always"
}

rg_query() {
    selected="$1"
    file_path="$2"

    # NOTE: --quiet --word-regexp --case-sensitive
    # more info `man rg`

    rg -qsw "$selected" "$file_path"
}

selected=$(bat "$commands_file" "$languages_file" "$defaults_file" | fzf)
[ -z "$selected" ] && exit 0

if rg -qsw "$selected" "$defaults_file"; then
    tmux_curl ":$(safe_print "$selected")"
    exit 1
fi

printf "Enter Query: " && read -r query
query=$(safe_print "$query" | tr ' ' '+')

if [ -n "$query" ] && rg_query "$selected" "$languages_file"; then
    tmux_curl "$(safe_print "$selected")/$(safe_print "$query")"
elif rg_query "$selected" "$languages_file"; then
    tmux_curl "$(safe_print "$selected")$(safe_print "$query")"
else
    tmux_curl "$(safe_print "$selected")~$(safe_print "$query")"
fi

exit 1
