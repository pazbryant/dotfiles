#!/bin/env sh

github() {
  check_git_status() {
    if [ -d "$1/.git" ]; then
      short_path="${1#/*/*/*/*}"
      if [ "$(git -C "$1" status --porcelain)" != "" ]; then
        printf "⁉️ %s\n" "$short_path"
      fi
      if git -C "$dir" cherry -v >/dev/null 2>&1; then
        printf "⚡ %s\n" "$short_path"
      fi
    fi
  }

  traverse_directories() {
    for dir in "$1"/*; do
      if [ -d "$dir" ]; then
        check_git_status "$dir"
        traverse_directories "$dir"
      fi
    done

  }

  traverse_all_directories() {
    for parent_dir in $1; do
      traverse_directories "$parent_dir"
    done
  }

  dirs="/home/bryant/Documents/work /home/bryant/Documents/github"
  traverse_all_directories "$dirs"
}

github
