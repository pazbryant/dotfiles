#!/bin/env sh

yy() {
  tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(cat -- "$tmp")" && [ "$cwd" != "" ] && [ "$cwd" != "$PWD" ]; then
    cd -- "$cwd" || return
  fi
  rm -f -- "$tmp"
}

xevkeys() {
  xev | awk -F'[ )]+' '/^KeyPress/ { a[NR+2] } NR in a { printf "%-3s %s\n", $5, $8 }'
}

# Function to reload the Zsh configuration
reload() {
  . /home/bryant/.zshrc
}

ds() {
  if [ "$1" = "" ]; then
    echo "Usage: check_disk_space /dev/sdax"
    return 1
  fi

  df -h "$1" | awk 'NR==2 {print "Total space on", $1, ":", $2, "| Free space:", $4}'
}

update_grub() {
  sudo grub-mkconfig -o /boot/grub/grub.cfg
}

copy_terminal_buffer() {
  echo "$BUFFER" | xclip -selection clipboard
  zle reset-prompt
}

sshadd() {
  sshpass_add() {
    echo "Checking if SSH keys are already loaded..."
    if ssh-add -l >/dev/null 2>&1; then
      echo "SSH keys are already loaded."
      return 0
    fi

    if [ -z "$SSH_AUTH_SOCK" ]; then
      echo "No SSH agent found. Starting a new agent..."
      eval "$(ssh-agent -s)"

      echo "Retrieving passphrase from pass..."
      passphrase=$(pass ssh/personal_github) || {
        echo "Failed to retrieve passphrase from pass." >&2
        return 1
      }

      echo "Adding SSH key to agent..."
      if ! sshpass -P "Enter passphrase" -p "$passphrase" ssh-add ~/.ssh/personal_github; then
        echo "Failed to add SSH key." >&2
        return 1
      fi
    fi

    echo "SSH agent has been cached and SSH key added successfully."
    return 0
  }
  sshpass_add
}
