#!/usr/bin/env zsh

autoload -U compinit && compinit

# set emacs keybind
bindkey -e

# custom keybind
zle -N copy_terminal_buffer

bindkey '^X' copy_terminal_buffer # copy buffer terminal to clipboard

setopt HIST_IGNORE_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_IGNORE_ALL_DUPS

# disable "c-s delay"
stty -ixon

# extend path
extra_path=(
  ~/bin/global/
  ~/.cargo/bin/
  ~/.local/bin/
  ~/bin/global/tmux/
  ~/.local/share/bob/nvim-bin/
  ~/.local/share/nvim/mason/bin/
  /usr/local/bin/
  /var/lib/flatpak/exports/bin/
)
extra_path_expanded=$(printf "%s:" "${extra_path[@]}")
export PATH="${extra_path_expanded}${PATH}"

# custom plugin manager
# function can be found in ~/.zshplugin
repos=(
  z-shell/zsh-eza
  zsh-users/zsh-autosuggestions
  zsh-users/zsh-syntax-highlighting
  hlissner/zsh-autopair
  jeffreytse/zsh-vi-mode
)

# zsh-autosuggestions strategy
ZSH_AUTOSUGGEST_STRATEGY=(completion history)

# load plugins
plugin-load $repos

# start software
eval "$(fzf --zsh)"
eval "$(starship init zsh)"
eval "$(fnm env --use-on-cd)"
eval "$(zoxide init --cmd cd zsh)"

# execute ater zsh-vim-mode k
zvm_after_init_commands+=(
  eval "$(atuin init zsh)"
  autopair-init
)

# gpg tty session
GPG_TTY=$(tty)
export GPG_TTY

# ssh private key autoload
# function can be found in ~/.functions
sshadd
